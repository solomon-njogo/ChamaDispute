rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      // For this applet preview, we might not have a full auth flow yet, 
      // but the tool requires security. Let's allow public read for now 
      // or check request.auth if the user is logged in.
      // In AI Studio, users are usually authenticated via Google.
      return request.auth != null;
    }

    // Chama Metadata
    match /chama/metadata {
      allow read: if true;
      allow write: if true; 
      
      match /bylaws/{bylawId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Members
    match /members/{userId} {
      allow read: if true;
      allow write: if true; 
    }

    // Statements
    match /statements/{entryId} {
      allow read: if true;
      allow write: if true;
    }

    // Disputes
    match /disputes/{disputeId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
