rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      // In this app, we assume the first user or a specifically marked user is admin
      // For now, let's allow all signed in users to read metadata and bylaws
      return isSignedIn();
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Chama Metadata
    match /chama/metadata {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for now, though should be restricted to treasurer
    }

    // Bylaws
    match /chama/bylaws/{bylawId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    // Members
    match /members/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isSignedIn(); 
    }

    // Statements
    match /statements/{entryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Disputes
    match /disputes/{disputeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
