{
  "entities": {
    "Chama": {
      "title": "Chama Metadata",
      "description": "Metadata for the investment group",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Bylaw": {
      "title": "Chama Bylaw",
      "description": "A specific rule or clause from the constitution",
      "type": "object",
      "properties": {
        "article": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["article", "content"]
    },
    "Member": {
      "title": "Chama Member",
      "description": "Profile of a chama member",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "standing": { "type": "string", "enum": ["good", "warning", "defaulter"] }
      },
      "required": ["memberId", "fullName"]
    },
    "StatementEntry": {
      "title": "Statement Entry",
      "description": "A single transaction from an M-Pesa or bank statement",
      "type": "object",
      "properties": {
        "receiptNo": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "details": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "memberId": { "type": "string" }
      },
      "required": ["receiptNo", "date", "amount"]
    },
    "DisputeCase": {
      "title": "Dispute Case",
      "description": "A legal/financial dispute recorded for arbitration",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "claim": { "type": "string" },
        "language": { "type": "string" },
        "evidence": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "ruling": {
          "type": "object",
          "properties": {
            "caseSummary": { "type": "string" },
            "relevantBylaws": { "type": "array", "items": { "type": "string" } },
            "evidenceAnalysis": { "type": "string" },
            "ruling": { "type": "string" },
            "recommendedAction": { "type": "string" },
            "preventiveMeasure": { "type": "string" }
          }
        }
      },
      "required": ["memberId", "claim", "status"]
    }
  },
  "firestore": {
    "/chama/metadata": {
      "schema": "Chama",
      "description": "Main chama settings"
    },
    "/chama/bylaws/{bylawId}": {
      "schema": "Bylaw",
      "description": "Constitutional clauses"
    },
    "/members/{userId}": {
      "schema": "Member",
      "description": "User profiles"
    },
    "/statements/{entryId}": {
      "schema": "StatementEntry",
      "description": "Transaction logs for analysis"
    },
    "/disputes/{disputeId}": {
      "schema": "DisputeCase",
      "description": "Active and past disputes"
    }
  }
}
